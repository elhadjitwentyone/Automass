# Meta Pixel — ID du pixel Facebook/Meta (visible dans Events Manager)
NEXT_PUBLIC_META_PIXEL_ID=

# Google Sheets Webhook — URL Make/Zapier pour logger les commandes (optionnel)
NEXT_PUBLIC_GS_WEBHOOK=

# URL publique du site (utilisée pour les balises Open Graph)
# Ex : https://automass.vercel.app ou https://www.automass.sn
NEXT_PUBLIC_SITE_URL=
